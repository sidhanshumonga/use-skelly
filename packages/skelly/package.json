{
  "name": "skellyjs",
  "version": "0.1.0",
  "description": "Skeletons that draw themselves. Layout-driven skeleton state library.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "skelly": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./style.css": "./dist/style.css",
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "default": "./dist/vue.js"
    },
    "./svelte": {
      "types": "./dist/svelte.d.ts",
      "default": "./dist/svelte.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "default": "./dist/next.js"
    },
    "./build": {
      "types": "./dist/build.d.ts",
      "default": "./dist/build.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && cp src/style.css dist/style.css",
    "watch": "tsc -w"
  },
  "keywords": [
    "skeleton",
    "loading",
    "placeholder",
    "shimmer",
    "react",
    "nextjs",
    "vue",
    "svelte",
    "layout"
  ],
  "author": "Skelly Team",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "typescript": "^5.0.0"
  }
}
